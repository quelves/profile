# =============================================================================
# QWS — Quelves Platform | .gitignore Raíz
# =============================================================================
# Este archivo ignora TODO lo que NO debe persistir en git:
# - Credenciales, secrets, .env files
# - Dependencias (node_modules)
# - Builds y caches
# - Archivos del sistema operativo
# - Configuraciones locales de agentes IA
# - Datos locales de Docker
# =============================================================================

# ---------------------------------------------------------------------------
# CREDENCIALES Y SECRETS — NUNCA commitear
# ---------------------------------------------------------------------------
.env
.env.*
!.env.example
!.env.template
*.pem
*.key
*.p12
*.pfx
*.crt
*.cer
secrets/
secrets.*
credentials/
credentials.*
*.secret
*.password
*.pass
id_rsa*
*.pub

# ---------------------------------------------------------------------------
# CONFIGURACIONES LOCALES DE AGENTES IA
# ---------------------------------------------------------------------------
.claude/
.kimi/

# ---------------------------------------------------------------------------
# DIRECTORIO DE ARCHIVOS NO COMMITEABLES
# ---------------------------------------------------------------------------
.no_commit/

# ---------------------------------------------------------------------------
# DEPENDENCIAS
# ---------------------------------------------------------------------------
node_modules/
.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions
vendor/

# ---------------------------------------------------------------------------
# BUILDS Y OUTPUTS
# ---------------------------------------------------------------------------
/build/
dist/
.out/
.next/
*.tsbuildinfo
next-env.d.ts

# ---------------------------------------------------------------------------
# ARCHIVOS DEL SISTEMA OPERATIVO
# ---------------------------------------------------------------------------
.DS_Store
Thumbs.db
desktop.ini
*.swp
*.swo
*~

# ---------------------------------------------------------------------------
# LOGS Y DEBUG
# ---------------------------------------------------------------------------
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# ---------------------------------------------------------------------------
# TESTING Y COVERAGE
# ---------------------------------------------------------------------------
coverage/
.nyc_output/

# ---------------------------------------------------------------------------
# VERCEL / DEPLOY LOCAL
# ---------------------------------------------------------------------------
.vercel

# ---------------------------------------------------------------------------
# DOCKER LOCAL
# ---------------------------------------------------------------------------
*.local.yml
*.local.yaml
docker-compose.override.yml

# ---------------------------------------------------------------------------
# DATOS LOCALES (NO COMMITEAR VOLUMES)
# ---------------------------------------------------------------------------
*.local
*.sqlite
*.sqlite3

# ---------------------------------------------------------------------------
# IDE / EDITORES
# ---------------------------------------------------------------------------
.idea/
.vscode/*
!.vscode/settings.json
!.vscode/extensions.json
*.sublime-*
